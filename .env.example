# ==============================================================================
# Cross-Task Multilingual Token Efficiency Study - Configuration
# ==============================================================================

# [REQUIRED] Groq API Key
# Sign up and retrieve your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_actual_groq_api_key_here

# ------------------------------------------------------------------------------
# Model Controls
# ------------------------------------------------------------------------------
# [OPTIONAL] Set to True only if you have a paid Groq key with a high TPM limit 
# and wish to enable qwen3-32b (which buffers internal chain-of-thought tokens).
INCLUDE_QWEN=False

# ------------------------------------------------------------------------------
# Dataset & Caching Configuration
# ------------------------------------------------------------------------------
# Directory where cached benchmark datasets (GSM8k, ARC-Easy, MBPP) are stored.
# Hard requirement for McNemar's paired testing across languages.
CACHE_DIR=data/cache

# Random seed used to shuffle and sample HuggingFace benchmark splits
DATASET_SEED=42

# ------------------------------------------------------------------------------
# Experiment Hyperparameters & Paths
# ------------------------------------------------------------------------------
# Directory for state tracking (run_state.json) and outputs (summary.csv)
RESULTS_DIR=results

# Number of questions sampled per task/language cell
N_SAMPLES=500

# API parameters
MAX_COMPLETION_TOKENS=5000
TEMPERATURE=0.0

# ------------------------------------------------------------------------------
# Rate-Limit & Backoff Courtesy Controls
# ------------------------------------------------------------------------------
MAX_RETRIES=6
RETRY_BASE_DELAY=15        # Base delay in seconds (doubles with each attempt)
INTER_QUESTION_DELAY=1.2   # Delay between questions in seconds